using System;

namespace MethodPower
{
    internal class Program
    {
        static double GetPow(double number, int power)
        {
            double result = 1;
            
            if (power == 0)
                return 1;
                
            for (int i = 0; i < Math.Abs(power); i++)
            {
                result *= number;
            }
            
            if (power < 0)
                result = 1.0 / result;
                
            return result;
        }
        
        static void Main(string[] args)
        {
            Console.Title = "Работа 5. Возведение в степень";
            
            Console.Write("Введите число: ");
            double number = double.Parse(Console.ReadLine());
            
            Console.Write("Введите степень: ");
            int power = int.Parse(Console.ReadLine());
            
            double result = GetPow(number, power);
            
            Console.WriteLine($"\n{number}^{power} = {result}");
            Console.WriteLine($"Проверка через Math.Pow: {Math.Pow(number, power)}");
            
            Console.WriteLine("\nТаблица степеней:");
            for (int i = -3; i <= 3; i++)
            {
                Console.WriteLine($"{number}^{i} = {GetPow(number, i):F4}");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
