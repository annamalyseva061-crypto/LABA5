using System;

namespace MethodPerimeter
{
    internal class Program
    {
        static double Perimeter(double a, double b, double c)
        {
            return a + b + c;
        }
        
        static void Main(string[] args)
        {
            Console.Title = "Работа 5. Периметр треугольника";
            
            Console.Write("Введите длину стороны a: ");
            double a = double.Parse(Console.ReadLine());
            
            Console.Write("Введите длину стороны b: ");
            double b = double.Parse(Console.ReadLine());
            
            Console.Write("Введите длину стороны c: ");
            double c = double.Parse(Console.ReadLine());
            
            if (a + b > c && a + c > b && b + c > a)
            {
                double p = Perimeter(a, b, c);
                Console.WriteLine($"\nПериметр треугольника: {p:F2}");
            }
            else
            {
                Console.WriteLine("\nТреугольник с такими сторонами не существует");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
